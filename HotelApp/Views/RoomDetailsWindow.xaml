<Window x:Class="HotelApp.Views.RoomDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:HotelApp.Models"
        Title="Room Operational Management" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Name="lblRoomHeader" Text="Room Fund: Room #000" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Comfort Class:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox Name="cbRoomClass" Width="180" Height="24"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Current Status:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <CheckBox Name="chbIsOccupied" Content="Occupied by Resident" VerticalAlignment="Center" Checked="ChbIsOccupied_Changed" Unchecked="ChbIsOccupied_Changed"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Name="panelGuest" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Guest Full Name:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox Name="txtGuestName" Width="180" Height="24" VerticalContentAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="4" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Name="btnDelete" Content="Delete" Click="BtnDelete_Click" Background="#BA0C2F" Foreground="White" FontWeight="Bold" Width="90" Height="30"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Name="btnSave" Content="Save Data" Click="BtnSave_Click" Background="#107C41" Foreground="White" FontWeight="Bold" Width="90" Height="30" Margin="0,0,10,0"/>
                <Button Name="btnCancel" Content="Cancel" Click="BtnCancel_Click" Background="#F3F2F1" Width="80" Height="30"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>