<Window x:Class="HotelApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HotelApp.Views"
        xmlns:core="clr-namespace:HotelApp.Core"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <core:BooleanToStatusConverter x:Key="BooleanToStatusConverter"/>
        <core:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#FFFFFF" Padding="5">
            <MenuItem Header="_File">
                <MenuItem Name="menuOpen" Header="_Open Configuration File..."/>
                <MenuItem Name="menuSave" Header="_Save Current Status..."/>
                <Separator/>
                <MenuItem Name="menuExit" Header="_Exit Application"/>
            </MenuItem>
            <MenuItem Header="_Reporting Filters">
                <MenuItem Name="menuShowAll" Header="Show All Hotel Rooms" IsCheckable="True" IsChecked="True"/>
                <MenuItem Name="menuShowVacant" Header="Show Vacant Rooms Only" IsCheckable="True"/>
                <MenuItem Name="menuShowOccupied" Header="Show Occupied Rooms Only" IsCheckable="True"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">

                <GroupBox Header="Hotel Configuration" Padding="8" Margin="0,0,0,12" FontWeight="SemiBold">
                    <StackPanel>
                        <TextBlock Text="Total Number of Rooms:" Margin="0,0,0,5" Foreground="#555555" FontWeight="Normal"/>
                        <TextBox Name="txtTotalRooms" Text="20" Padding="4" Margin="0,0,0,8" FontWeight="Normal"/>
                        <Button Name="btnInitialize" Content="Initialize Hotel Fund" Padding="6" Margin="0,0,0,6" Background="#007ACC" Foreground="White"/>
                        <Button Name="btnOpenRoomCreation" Content="Add Single New Room..." Padding="6" Margin="0,0,0,6" Background="#007ACC" Foreground="White"/>
                        <Button Name="btnGenerateData" Content="Mock Random Guests" Padding="6" Background="#E1DFDD" FontWeight="Normal"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Management Operations" Padding="8" FontWeight="SemiBold">
                    <StackPanel>
                        <Button Name="btnOpenCheckIn" Content="Check-In New Resident..." Padding="8" Margin="0,0,0,15" Background="#107C41" Foreground="White"/>

                        <Separator Margin="0,0,0,15"/>

                        <TextBlock Text="Target Room Number:" Margin="0,0,0,5" Foreground="#555555" FontWeight="Normal"/>
                        <TextBox Name="txtRoomToVacate" Padding="4" Margin="0,0,0,8" FontWeight="Normal"/>
                        <Button Name="btnCheckOut" Content="Vacate Selected Room" Padding="6" Background="#A80000" Foreground="White"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>

            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Live Database Registry Grid:" VerticalAlignment="Center" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#333333"/>

                <DataGrid Grid.Row="1" Name="dgRoomRegistry" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal" 
                  HeadersVisibility="Column"
                  Background="White" 
                  BorderBrush="#E1DFDD" 
                  RowHeight="28"
                  MouseDoubleClick="DgRoomRegistry_MouseDoubleClick">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F2F1"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,4,8,4"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E1DFDD"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Room Number" Binding="{Binding Number}" Width="110"/>
                        <DataGridTextColumn Header="Comfort Class" Binding="{Binding Class}" Width="140"/>

                        <DataGridTemplateColumn Header="Status" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsOccupied, Converter={StaticResource BooleanToStatusConverter}}" 
                                   FontWeight="SemiBold"
                                   Foreground="{Binding IsOccupied, Converter={StaticResource BooleanToColorConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Current Occupant Full Name" Binding="{Binding GuestName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>